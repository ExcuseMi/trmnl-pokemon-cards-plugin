<script>
  (function() {
    var views  = Array.from(document.querySelectorAll('.view'));
    var host   = document.currentScript.closest('.view') || document.body;
    var pool   = __pkmn || [];
    var idx    = views.indexOf(host) % 4;
    var item   = pool.length ? pool[idx % pool.length] : null;
    var name   = '{{ trmnl.plugin_settings.instance_name | escape }}';
    function q(sel) { return host.querySelector(sel); }

    var titleEl = q('.pkmn-title');
    var instEl  = q('.pkmn-instance');

    if (!item || (!item.image_large && !item.name)) {
      if (titleEl) titleEl.textContent = name;
      host.querySelectorAll('.pkmn-img').forEach(function(img) { img.src = ''; img.alt = ''; });
      return;
    }

    host.querySelectorAll('.pkmn-img').forEach(function(img) {
      if (item.image_large) { img.src = item.image_large; img.alt = item.name || ''; }
      else { img.src = ''; img.alt = ''; }
    });
    if (item && item.set_symbol) {
      host.querySelectorAll('.set_symbol').forEach(function(img) {
        img.src = item.set_symbol; }
                                                  );
    } else {
      show('pokemon-logo');
    }
    var nameEl = q('.pkmn-name');
    if (nameEl) nameEl.textContent = item.name || '';
    function show(key) {
      host.querySelectorAll('.' + key).forEach(function(el) {
        el.classList.remove('hidden');
      });
    }

    function show2(key, value, extraClass) {
      if (!value && value !== 0) return;
      var val = q('.pkmn-' + key);
      var row = q('.pkmn-' + key + '-row');
      if (val) {
        val.textContent = String(value);
        if (extraClass) val.classList.add(extraClass);
      }
      if (row) row.classList.remove('hidden');
    }

    function rarityClass(r) {
      r = (r || '').toLowerCase();
      if (r.includes('special illustration') || r.includes('hyper')) return 'label--error';
      if (r.includes('illustration'))  return 'label--warning';
      if (r.includes('ultra') || r.includes('secret') || r.includes('rainbow')) return 'label--primary';
      if (r.includes('rare')) return 'label--primary';
      return '';
    }

    show2('dex-id', item.dexId ? '#' + item.dexId : '');
    show2('illustrator', item.illustrator);
    show2('hp', item.hp);
    show2('types', item.types ? item.types.join(', ') : '');
    show2('stage', item.stage);
    show2('rarity', item.rarity, rarityClass(item.rarity));
    //show2('retreat', item.retreat != null ? item.retreat : '');
    show2('regulation', item.regulation_mark);

    var VARIANT_LABELS = { holo: 'HOLO', reverse: 'REV', firstEdition: '1ST', normal: 'NORM', wPromo: 'PROMO' };
    var variantOrder = ['normal', 'holo', 'reverse', 'firstEdition', 'wPromo'];
    if (item.variants) {
      var container = q('.pkmn-variants');
      var hasAny = false;
      variantOrder.forEach(function(key) {
        if (!item.variants[key]) return;
        hasAny = true;
        var span = document.createElement('span');
        span.className = 'label label--base label--inverted rounded pl--2 pr--2';
        span.textContent = VARIANT_LABELS[key];
        if (container) container.appendChild(span);
      });
      if (hasAny) {
        var vrow = q('.pkmn-variants-row');
        if (vrow) vrow.classList.remove('hidden');
      }
    }

    if (item.card_count) {
      var official = item.card_count.official;
      var total = item.card_count.total;
      if (item.localId != null && item.localId !== '' && official != null) {
        var countStr = item.localId + ' / ' + official;
        if (total != null && total !== official) countStr += ' (' + total + ')';
        show2('card-count', countStr);
      }
    }

    var price = item.price || {};
    if (!price.avg && item.pricing && item.pricing.cardmarket) {
      var cm = item.pricing.cardmarket;
      var sym = cm.unit === 'EUR' ? '€' : (cm.unit === 'USD' ? '$' : (cm.unit || '') + ' ');
      function fmtP(v) { return v != null ? sym + Number(v).toFixed(2) : ''; }
      price.avg  = fmtP(cm.avg);
      price.avg7 = fmtP(cm.avg7);
      price.low  = fmtP(cm.low);
    }
    if (!price.tcg_market && item.pricing && item.pricing.tcgplayer) {
      var tcg = item.pricing.tcgplayer;
      var tsym = tcg.unit === 'USD' ? '$' : (tcg.unit === 'EUR' ? '€' : (tcg.unit || '') + ' ');
      var normal = tcg.normal || {};
      function fmtT(v) { return v != null ? tsym + Number(v).toFixed(2) : ''; }
      price.tcg_market = fmtT(normal.marketPrice);
      price.tcg_low    = fmtT(normal.lowPrice);
    }
    if (price.avg && price.tcg_market) {
      show2('price-avg', price.avg + ' · ' + price.tcg_market);
    } else {
      show2('price-avg', price.avg);
      show2('price-tcg-market', price.tcg_market);
    }
    show2('price-avg7', price.avg7);
    show2('price-tcg-low', price.tcg_low);

    var titleBarEl = host.querySelector('.title_bar');
    var titleBarVisible = {{ view }} !== 4 && titleBarEl && titleBarEl.offsetHeight > 0;
    if (!titleBarVisible) show2('set-name', item.set_name);
    show2('serie', item.serie_name);
    show2('release-date', item.set_release_date);

    if (item.set_logo) {
      var setLogoEl = q('.pkmn-set-logo');
      if (setLogoEl) {
        setLogoEl.src = item.set_logo;
        setLogoEl.alt = item.set_name || '';
        setLogoEl.classList.remove('hidden');
        var setRow = q('.pkmn-set-row');
        if (setRow) setRow.classList.remove('hidden');
      }
    }

    if (titleEl) titleEl.textContent = item.name || '';
    var cardCountRow = q('.pkmn-card-count-row');
    var cardCountShown = cardCountRow && !cardCountRow.classList.contains('hidden');
    var instLabel = item.set_name || '';
    if (!cardCountShown && item.localId && item.card_count && item.card_count.official) {
      instLabel += ' (' + item.localId + '/' + item.card_count.official + ')';
    }
    if (instEl) instEl.textContent = instLabel;
  })();
</script>


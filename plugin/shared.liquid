{% template main %}
{% assign display_mode = trmnl.plugin_settings.custom_fields_values.display_mode | default: 'stats' %}
{% if view == 1 %}
{% assign lbl_cls = "label label--base lg:label--xlarge bg--gray-75 rounded pl--2 pr--2" %}
{% assign val_cls = "description description--large lg:description--xxlarge" %}
{% assign hp_cls  = "description description--large lg:description--xxlarge" %}
{% assign rar_cls = "label label--base lg:label--large" %}
{% else %}
{% assign lbl_cls = "label label--base lg:label--large bg--gray-75 rounded pl--2 pr--2" %}
{% assign val_cls = "description description--large lg:description--xlarge" %}
{% assign hp_cls  = "description description--large lg:description--xlarge" %}
{% assign rar_cls = "label label--base" %}
{% endif %}

<script>var __pkmn = {{ items | json }};</script>

<div class="layout {% unless view == 3%}layout--row {% else %}layout--col{% endunless %} gap--medium h--full">
  <img class="pkmn-img image image image-dither image--contain h--full
    {% if view == 1  %}    portrait:hidden lg:portrait:block
    {% elsif view == 2  %}
    {% elsif view == 3  %} portrait:hidden lg:hidden
    {% elsif view == 4  %} portrait:hidden
    {% endif %}"
    alt="height">
  <img class="pkmn-img image image-dither image--contain w--full
    {% if view == 1  %}    hidden portrait:block lg:portrait:hidden
    {% elsif view == 2  %} hidden
    {% elsif view == 3  %} hidden portrait:block lg:block
    {% elsif view == 4  %} hidden portrait:block
    {% endif %}"
    alt="">

  <div class="flex--col gap--small stretch-x w--full h--full
    {% if view == 1 %}   flex portrait:hidden
    {% elsif view == 2 %}flex portrait:hidden lg:portrait:flex
    {% elsif view == 3 %}hidden portrait:flex
    {% elsif view == 4 %}flex portrait:hidden portrait:m::flex lg:portrait:hidden
    {% endif %}">
    <span class="label label--primary label--xlarge lg:label--xxxlarge pkmn-name" data-clamp="2"></span>
    {% unless view == 2 %}
    <div class="item pkmn-rarity-row hidden">
      <div class="content flex flex--row flex--center-y gap--small">
        <span class="{{ lbl_cls }}">{{ labels.rarity }}</span>
        <span class="{{ rar_cls }} pkmn-rarity"></span>
      </div>
    </div>
    <div class="item pkmn-card-count-row hidden">
      <div class="content flex flex--row flex--center-y gap--small">
        <span class="{{ lbl_cls }}">{{ labels.number }}</span>
        <span class="{{ val_cls }} pkmn-card-count"></span>
      </div>
    </div>
    <div class="item pkmn-set-name-row hidden">
      <div class="content flex flex--row flex--center-y gap--small">
        <span class="{{ lbl_cls }}">{{ labels.set }}</span>
        <span class="{{ val_cls }} pkmn-set-name"></span>
      </div>
    </div>
    <div class="item pkmn-serie-row hidden">
      <div class="content flex flex--row flex--center-y gap--small">
        <span class="{{ lbl_cls }}">{{ labels.serie }}</span>
        <span class="{{ val_cls }} pkmn-serie"></span>
      </div>
    </div>
    <div class="item pkmn-illustrator-row hidden">
      <div class="content flex flex--row flex--center-y gap--small">
        <span class="{{ lbl_cls }}">{{ labels.artist }}</span>
        <span class="{{ val_cls }} pkmn-illustrator"></span>
      </div>
    </div>
    {% unless view == 4 %}
    <div class="item pkmn-release-date-row hidden">
      <div class="content flex flex--row flex--center-y gap--small">
        <span class="{{ lbl_cls }}">{{ labels.released }}</span>
        <span class="{{ val_cls }} pkmn-release-date"></span>
      </div>
    </div>
    {% endunless %}
    {% endunless %}
    <div class="w--full {% if view <= 2 %}grid grid--cols-2 gap--small{% if view == 2 %} lg:portrait:flex lg:portrait:flex--col{% endif %}{% else %}flex flex--col{% endif %}">
      {% if view == 2 %}
      <div class="item pkmn-rarity-row hidden">
        <div class="content flex flex--row flex--center-y gap--small">
          <span class="{{ lbl_cls }}">{{ labels.rarity }}</span>
          <span class="{{ rar_cls }} pkmn-rarity"></span>
        </div>
      </div>
      <div class="item pkmn-card-count-row hidden">
        <div class="content flex flex--row flex--center-y gap--small">
          <span class="{{ lbl_cls }}">{{ labels.number }}</span>
          <span class="{{ val_cls }} pkmn-card-count"></span>
        </div>
      </div>
      <div class="item pkmn-set-name-row hidden">
        <div class="content flex flex--row flex--center-y gap--small">
          <span class="{{ lbl_cls }}">{{ labels.set }}</span>
          <span class="{{ val_cls }} pkmn-set-name"></span>
        </div>
      </div>
      <div class="item pkmn-serie-row hidden">
        <div class="content flex flex--row flex--center-y gap--small">
          <span class="{{ lbl_cls }}">{{ labels.serie }}</span>
          <span class="{{ val_cls }} pkmn-serie"></span>
        </div>
      </div>
      <div class="item pkmn-illustrator-row hidden">
        <div class="content flex flex--row flex--center-y gap--small">
          <span class="{{ lbl_cls }}">{{ labels.artist }}</span>
          <span class="{{ val_cls }} pkmn-illustrator"></span>
        </div>
      </div>
      {% endif %}

      {% if view != 4 %}
      {% if view != 2 %}
      <div class="item pkmn-hp-row hidden">
        <div class="content flex flex--row flex--center-y gap--small">
          <span class="{{ lbl_cls }}">{{ labels.hp }}</span>
          <span class="{{ hp_cls }} pkmn-hp"></span>
        </div>
      </div>
      {% endif %}
      <div class="item pkmn-types-row hidden">
        <div class="content flex flex--row flex--center-y gap--small">
          <span class="{{ lbl_cls }}">{{ labels.type }}</span>
          <span class="{{ val_cls }} pkmn-types"></span>
        </div>
      </div>
      <div class="item pkmn-stage-row hidden">
        <div class="content flex flex--row flex--center-y gap--small">
          <span class="{{ lbl_cls }}">{{ labels.stage }}</span>
          <span class="{{ val_cls }} pkmn-stage"></span>
        </div>
      </div>
      <div class="item pkmn-retreat-row hidden">
        <div class="content flex flex--row flex--center-y gap--small">
          <span class="{{ lbl_cls }}">{{ labels.retreat }}</span>
          <span class="{{ val_cls }} pkmn-retreat"></span>
        </div>
      </div>
      <div class="item pkmn-dex-id-row hidden">
        <div class="content flex flex--row flex--center-y gap--small">
          <span class="{{ lbl_cls }}">Pokédex</span>
          <span class="{{ val_cls }} pkmn-dex-id"></span>
        </div>
      </div>
      <div class="item pkmn-release-date-row hidden">
        <div class="content flex flex--row flex--center-y gap--small">
          <span class="{{ lbl_cls }}">{{ labels.released }}</span>
          <span class="{{ val_cls }} pkmn-release-date"></span>
        </div>
      </div>
      {% endif %}

      {% if view == 4 %}
      <div class="hidden lg:flex lg:flex--col gap--small w--full">
        <div class="item pkmn-variants-row hidden">
          <div class="content flex flex--row flex--center-y gap--small flex--wrap">
            <span class="{{ lbl_cls }}">{{ labels.print }}</span>
            <div class="pkmn-variants flex flex--row gap--small flex--wrap"></div>
          </div>
        </div>
        <div class="item pkmn-types-row hidden md:hidden">
          <div class="content flex flex--row flex--center-y gap--small">
            <span class="{{ lbl_cls }}">{{ labels.type }}</span>
            <span class="{{ val_cls }} pkmn-types"></span>
          </div>
        </div>
        <div class="item pkmn-stage-row hidden">
          <div class="content flex flex--row flex--center-y gap--small">
            <span class="{{ lbl_cls }}">{{ labels.stage }}</span>
            <span class="{{ val_cls }} pkmn-stage"></span>
          </div>
        </div>
      </div>
      {% endif %}

      {% if view == 1 or view == 3 %}
      <div class="item pkmn-regulation-row hidden">
        <div class="content flex flex--row flex--center-y gap--small">
          <span class="{{ lbl_cls }}">{{ labels.mark }}</span>
          <span class="{{ val_cls }} w--4 text--center pkmn-regulation label--outline"></span>
        </div>
      </div>
      <div class="item pkmn-variants-row hidden">
        <div class="content flex flex--row flex--center-y gap--small flex--wrap">
          <span class="{{ lbl_cls }}">{{ labels.print }}</span>
          <div class="pkmn-variants flex flex--row gap--small flex--wrap"></div>
        </div>
      </div>
      {% endif %}



      <div class="item pkmn-price-avg-row hidden">
        <div class="content flex flex--row flex--center-y gap--small">
          <span class="{{ lbl_cls }}">{{ labels.avg }}</span>
          <span class="{{ val_cls }} pkmn-price-avg"></span>
        </div>
      </div>

      {% if view != 4 and view != 2 %}
      <div class="item pkmn-price-avg7-row hidden">
        <div class="content flex flex--row flex--center-y gap--small">
          <span class="{{ lbl_cls }}">{{ labels.avg7 }}</span>
          <span class="{{ val_cls }} pkmn-price-avg7"></span>
        </div>
      </div>
      {% endif %}

      <div class="item pkmn-price-tcg-market-row hidden">
        <div class="content flex flex--row flex--center-y gap--small">
          <span class="{{ lbl_cls }}">{{ labels.tcg_market }}</span>
          <span class="{{ val_cls }} pkmn-price-tcg-market"></span>
        </div>
      </div>

      {% if view != 4 %}
      <div class="item pkmn-price-tcg-low-row hidden">
        <div class="content flex flex--row flex--center-y gap--small">
          <span class="{{ lbl_cls }}">{{ labels.tcg_low }}</span>
          <span class="{{ val_cls }} pkmn-price-tcg-low"></span>
        </div>
      </div>
      {% endif %}



    </div>

    {% if view == 1 %}
    <div class="pkmn-set-row hidden">
      {% comment %}Image could be bigger, but it takes away to much attention from the card.{% endcomment %}
      <img class="pkmn-set-logo hidden image--contain w--[30cqw] mt--1 lg:mt--8 md:h--max-32 lg:h--max-64" alt="">
    </div>
    {% endif %}
  </div>
</div>


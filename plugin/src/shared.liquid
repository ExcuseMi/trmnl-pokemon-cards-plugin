{% template main %}
{% assign display_mode = trmnl.plugin_settings.custom_fields_values.display_mode | default: 'stats' %}

<script>var __pkmn = {{ items | json }};</script>

{% if display_mode == 'art' or view == 4 %}

<div class="layout layout--stretch gap--none m--0 p--0">
  <img class="pkmn-img hidden image image-dither image--contain" alt="">
  <div class="pkmn-empty hidden flex flex--col flex--center gap--small">
    <span class="label label--small">Pokémon Cards</span>
    <span class="description text--center">No card available.</span>
  </div>
</div>

{% else %}

<div class="flex flex--row gap--medium h--full">

  <img class="pkmn-img hidden image image-dither image--contain h--full" alt="">

  <div class="flex flex--col gap--small stretch-x flex--center-y">

    <span class="title pkmn-name" data-clamp="2"></span>

    <div class="pkmn-hp-row hidden flex flex--row flex--center-y gap--small">
      <span class="label label--small label--filled">HP</span>
      <span class="description pkmn-hp"></span>
    </div>

    <div class="pkmn-type-row hidden flex flex--row flex--center-y gap--small">
      <span class="label label--small">Type</span>
      <span class="description pkmn-types"></span>
    </div>

    {% if view == 1 or view == 3 %}
    <div class="pkmn-rarity-row hidden flex flex--row flex--center-y gap--small">
      <span class="label label--small">Rarity</span>
      <span class="description pkmn-rarity"></span>
    </div>
    {% endif %}

    <div class="pkmn-set-row hidden">
      <img class="pkmn-set-logo hidden h--12 w--auto image--contain" alt="">
    </div>

  </div>
</div>

{% endif %}

<div class="title_bar">
  <svg class="image" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
    <circle cx="24" cy="24" r="22" fill="white" stroke="black" stroke-width="1"/>
    <path d="M2 24 A22 22 0 0 1 46 24 Z" fill="#f8654b"/>
    <rect x="2" y="21" width="44" height="6" fill="black"/>
    <circle cx="24" cy="24" r="8" fill="black"/>
    <circle cx="24" cy="24" r="5" fill="white"/>
  </svg>
  <span class="title pkmn-title"></span>
  <span class="instance pkmn-instance"></span>
</div>

<script>
(function() {
  var self   = document.currentScript;
  var views  = Array.from(document.querySelectorAll('.view'));
  var host   = views.find(function(v) { return v.contains(self); }) || document.body;
  var idx    = views.indexOf(host) % 4;
  var item   = (__pkmn || [])[idx] || null;
  var name   = '{{ trmnl.plugin_settings.instance_name | escape }}';
  var isImageOnly = !host.querySelector('.pkmn-name');

  function q(sel) { return host.querySelector(sel); }
  function show(el) { if (el) el.classList.remove('hidden'); }

  var titleEl = q('.pkmn-title');
  var instEl  = q('.pkmn-instance');

  if (!item || (!item.image_large && !item.name)) {
    show(q('.pkmn-empty'));
    if (titleEl) titleEl.textContent = name;
    return;
  }

  var img = q('.pkmn-img');
  if (img && item.image_large) {
    img.src = item.image_large;
    img.alt = item.name || '';
    show(img);
  } else {
    show(q('.pkmn-empty'));
  }

  if (isImageOnly) {
    if (titleEl) titleEl.textContent = item.name || '';
    if (instEl)  instEl.textContent  = item.set_name || '';
  } else {
    var nameEl = q('.pkmn-name');
    if (nameEl) nameEl.textContent = item.name || '';

    if (item.hp) {
      var hpEl = q('.pkmn-hp');
      if (hpEl) hpEl.textContent = item.hp;
      show(q('.pkmn-hp-row'));
    }
    if (item.types_str) {
      var typesEl = q('.pkmn-types');
      if (typesEl) typesEl.textContent = item.types_str;
      show(q('.pkmn-type-row'));
    }
    if (item.rarity) {
      var rarityEl = q('.pkmn-rarity');
      if (rarityEl) rarityEl.textContent = item.rarity;
      show(q('.pkmn-rarity-row'));
    }
    if (item.set_logo) {
      var setLogoEl = q('.pkmn-set-logo');
      if (setLogoEl) {
        setLogoEl.src = item.set_logo;
        setLogoEl.alt = item.set_name || '';
        show(setLogoEl);
        show(q('.pkmn-set-row'));
      }
    }

    if (titleEl) titleEl.textContent = name;
    if (instEl)  instEl.textContent  = item.name || '';
  }
})();
</script>

{% endtemplate %}

{% template main %}
{% assign display_mode = trmnl.plugin_settings.custom_fields_values.display_mode | default: 'stats' %}

<script>var __pkmn = {{ items | json }};</script>

<div class="layout {% unless view == 3%}layout--row {% else %}layout--col{% endunless %} gap--medium h--full">
  <img class="pkmn-img image image image-dither image--contain h--full
  {% if view == 1  %}    portrait:hidden lg:portrait:block
  {% elsif view == 2  %}
  {% elsif view == 3  %} portrait:hidden lg:hidden
  {% elsif view == 4  %} portrait:hidden
  {% endif %}"
   alt="height">
  <img class="pkmn-img image image-dither image--contain w--full
  {% if view == 1  %}    hidden portrait:block lg:portrait:hidden
  {% elsif view == 2  %} hidden
  {% elsif view == 3  %} hidden portrait:block lg:block
  {% elsif view == 4  %} hidden portrait:block
  {% endif %}"

  " alt="">

  <div class="flex--col gap--small stretch-x flex--center-y outline
  {% if view == 1 %}   flex portrait:hidden
  {% elsif view == 2 %}flex portrait:hidden lg:portrait:flex
  {% elsif view == 3 %}hidden portrait:flex
  {% elsif view == 4 %}hidden portrait:m::flex lg:portrait:hidden
  {% endif %}" >
    <span class="label label--underline label--large lg:label--xlarge pkmn-name" data-clamp="2"></span>
    <div class="pkmn-hp-row hidden flex flex--row flex--center-y gap--small">
      <span class="label label--base lg:label--large label--filled">HP</span>
      <span class="description description--large lg:description--xlarge pkmn-hp"></span>
    </div>
    <div class="pkmn-type-row hidden flex flex--row flex--center-y gap--small">
      <span class="label label--base lg:label--large">Type</span>
      <span class="description description--large lg:description--xlarge pkmn-types"></span>
    </div>
    {% if view == 1 or view == 3 %}
    <div class="pkmn-rarity-row hidden flex flex--row flex--center-y gap--small">
      <span class="label label--base lg:label--large">Rarity</span>
      <span class="description description--large lg:description--xlarge pkmn-rarity"></span>
    </div>
    {% endif %}
    <div class="pkmn-set-row hidden">
      <img class="pkmn-set-logo hidden image--contain w--full" alt="">
    </div>
  </div>
</div>

<div class="title_bar
{% if view == 1 %}
lg:portrait:hidden
{% elsif view == 2 %}

{% elsif view == 3 %}

{% elsif view == 4 %}
lg:portrait:hidden
{% endif %}">
  <svg class="image" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
    <circle cx="24" cy="24" r="22" fill="white" stroke="black" stroke-width="1"/>
    <path d="M2 24 A22 22 0 0 1 46 24 Z" fill="#f8654b"/>
    <rect x="2" y="21" width="44" height="6" fill="black"/>
    <circle cx="24" cy="24" r="8" fill="black"/>
    <circle cx="24" cy="24" r="5" fill="white"/>
  </svg>
  <span class="title pkmn-title"></span>
  <span class="instance pkmn-instance"></span>
</div>

<script>
(function() {
  var self   = document.currentScript;
  var views  = Array.from(document.querySelectorAll('.view'));
  var host = document.currentScript.closest('.view') || document.body;
  var idx    = views.indexOf(host) % 4;
  var item   = (__pkmn || [])[idx] || null;
  var name   = '{{ trmnl.plugin_settings.instance_name | escape }}';
  var isImageOnly = !host.querySelector('.pkmn-name');
  function q(sel) { return host.querySelector(sel); }
  function show(el) { if (el) el.classList.remove('hidden'); }

  var titleEl = q('.pkmn-title');
  var instEl  = q('.pkmn-instance');

  if (!item || (!item.image_large && !item.name)) {
    show(q('.pkmn-empty'));
    if (titleEl) titleEl.textContent = name;
    // Clear all images when no item
    var allImgs = host.querySelectorAll('.pkmn-img');
    allImgs.forEach(function(img) {
      img.src = '';
      img.alt = '';
    });
    return;
  }

  // Update ALL images with the same src/alt
  var allImgs = host.querySelectorAll('.pkmn-img');
  if (item.image_large) {
    allImgs.forEach(function(img) {
      img.src = item.image_large;
      img.alt = item.name || '';
    });
  } else {
    allImgs.forEach(function(img) {
      img.src = '';
      img.alt = '';
    });
    show(q('.pkmn-empty'));
  }

  if (isImageOnly) {
    if (titleEl) titleEl.textContent = item.name || '';
    if (instEl)  instEl.textContent  = item.set_name || '';
  } else {
    var nameEl = q('.pkmn-name');
    if (nameEl) nameEl.textContent = item.name || '';

    if (item.hp) {
      var hpEl = q('.pkmn-hp');
      if (hpEl) hpEl.textContent = item.hp;
      show(q('.pkmn-hp-row'));
    }
    if (item.types_str) {
      var typesEl = q('.pkmn-types');
      if (typesEl) typesEl.textContent = item.types_str;
      show(q('.pkmn-type-row'));
    }
    if (item.rarity) {
      var rarityEl = q('.pkmn-rarity');
      if (rarityEl) rarityEl.textContent = item.rarity;
      show(q('.pkmn-rarity-row'));
    }
    if (item.set_logo) {
      var setLogoEl = q('.pkmn-set-logo');
      if (setLogoEl) {
        setLogoEl.src = item.set_logo;
        setLogoEl.alt = item.set_name || '';
        show(setLogoEl);
        show(q('.pkmn-set-row'));
      }
    }

    if (titleEl) titleEl.textContent = name;
    if (instEl)  instEl.textContent  = item.name || '';
  }
})();
</script>

{% endtemplate %}